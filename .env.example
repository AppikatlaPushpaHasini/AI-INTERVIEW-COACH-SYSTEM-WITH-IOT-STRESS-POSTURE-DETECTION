PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ai_interview
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_EMAIL=hasiniappikatla11@gmail.com
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
# Optional: comma-separated extra client IDs accepted by the backend.
GOOGLE_CLIENT_IDS=

# Optional: set true only when you want generated IoT readings during local demos.
IOT_AUTO_SIM_ENABLED=false

# Optional SMTP email delivery for support requests
# Install nodemailer and set these values to enable real email sending.
SUPPORT_SMTP_HOST=smtp.gmail.com
SUPPORT_SMTP_PORT=587
SUPPORT_SMTP_SECURE=false
SUPPORT_SMTP_USER=your-email@example.com
SUPPORT_SMTP_PASS=your-app-password
SUPPORT_FROM_EMAIL=your-email@example.com
SUPPORT_FROM_NAME=PrepGenie Support
SUPPORT_TO_EMAIL=hasiniappikatla11@gmail.com
